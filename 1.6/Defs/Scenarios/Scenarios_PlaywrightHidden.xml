<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ScenarioDef ParentName="ScenarioBase">
    <defName>Playwright_BlankScenario</defName>
    <label>(internal) pw blank scenario</label>
    <description>Create a custom Origin using the settings below.</description>
    <scenario>
      <showInUI>false</showInUI>
      <summary>Create a custom origin.</summary>
      <parts>
        <!-- Without DLC enabled, the game complains that this scenario has no parts, so we choose GameStartDialog which is the least impactful one, and gets replaced anyway. -->
        <li Class="ScenPart_GameStartDialog">
          <def>GameStartDialog</def>
          <textKey>GameStartDialog</textKey>
          <closeSound>GameStartSting</closeSound>
        </li>
      </parts>
    </scenario>
  </ScenarioDef>

  <ScenarioDef ParentName="ScenarioBase" MayRequire="Ludeon.RimWorld.Royalty">
    <defName>Playwright_Empire</defName>
    <label>Empire</label>
    <description>You recently joined the ranks of the Empire as Novices. For your first mission, you are sent out to do field work and establish another base of operations.</description>
    <scenario>
	    <showInUI>false</showInUI>
      <summary>Imperial Novices sent out into the field.</summary>
      <parts>
        
        <!-- Config pages -->
        <li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
          <def>ConfigPage_ConfigureStartingPawns</def>
          <pawnCount>5</pawnCount>
          <pawnChoiceCount>10</pawnChoiceCount>
        </li>

        <!-- Player starting stuff spawn method-->
        <li Class="ScenPart_PlayerPawnsArriveMethod">
          <def>PlayerPawnsArriveMethod</def>
          <method>DropPods</method>
          <visible>false</visible>
        </li>

        <!-- Player pawns modifiers -->
		
		<!-- Starting out allied with the Empire or psylinks intentionally omitted, will be default-selected in editor by the Origin instead -->
        
        <!-- Player starting things -->
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Silver</thingDef>
          <count>500</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Gold</thingDef>
          <count>100</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Steel</thingDef>
          <count>200</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>WoodLog</thingDef>
          <count>100</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MealSurvivalPack</thingDef>
          <count>50</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MedicineIndustrial</thingDef>
          <count>30</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>ComponentIndustrial</thingDef>
          <count>30</count>
        </li>
        <li Class="ScenPart_StartingAnimal">
          <def>StartingAnimal</def>
          <count>5</count>
          <bondToRandomPlayerPawnChance>1.0</bondToRandomPlayerPawnChance>
        </li> 

        <!-- Scatter some things anywhere -->
        <li Class="ScenPart_ScatterThingsAnywhere">
          <def>ScatterThingsAnywhere</def>
          <thingDef>WoodLog</thingDef>
          <count>50</count>
        </li>
        
        <!-- Game start dialog -->
        <li Class="ScenPart_GameStartDialog">
          <def>GameStartDialog</def>
          <textKey>GameStartDialog</textKey>
          <closeSound>GameStartSting</closeSound>
        </li>
        
      </parts>
    </scenario>
  </ScenarioDef>

</Defs>
